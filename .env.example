TELEGRAM_BOT_TOKEN=          # From @BotFather
TELEGRAM_WEBHOOK_SECRET=     # Self-generated random string for webhook verification
GROQ_API_KEY=                # From console.groq.com (used for both transcription and classification)
NOTION_TOKEN=                # From notion.so/my-integrations
NOTION_ACTIONS_DB_ID=        # Actions database ID (32-char hex from Notion URL)
NOTION_IDEAS_DB_ID=          # Ideas database ID (32-char hex from Notion URL)
GITHUB_TOKEN=                # GitHub PAT with repo scope (for Obsidian sync)
GITHUB_OBSIDIAN_REPO=        # e.g. jmaulana0/valis-obsidian-sync
